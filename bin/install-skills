#!/usr/bin/env bash
# Symlink skills from this repo into ~/.claude/skills/
#
# Behavior:
#   - Reads scopes from config.json (top-level "scopes" object).
#   - With no --scope: installs the union of all scopes.
#   - With --scope <name>: installs only that scope, AND removes existing
#     symlinks (pointing into this repo) for skills NOT in that scope.
#   - If target exists and is NOT a symlink: aborts with a warning.
#
# Output: one concise line per skill — identical / linked / relinked / unlinked.
#
# Requires: jq
#
# Usage:
#   bin/install-skills                          install all scopes
#   bin/install-skills --scope personal         install only "personal" scope
#   bin/install-skills --scope work             install only "work" scope
#   bin/install-skills --dry-run                preview without changes
#   bin/install-skills brainstorming foo        install specific skills (override)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_SRC="$REPO_ROOT/skills"
SKILLS_DST="$HOME/.claude/skills"
CONFIG="$REPO_ROOT/config.json"

dry_run=false
scope=""
selected=()

if ! command -v jq >/dev/null 2>&1; then
  echo "error: jq is required. Install with: brew install jq" >&2
  exit 1
fi

if [ ! -f "$CONFIG" ]; then
  echo "error: config.json not found at $CONFIG" >&2
  exit 1
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) dry_run=true; shift ;;
    --scope)
      [ $# -ge 2 ] || { echo "error: --scope requires a name" >&2; exit 2; }
      scope="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    -*)
      echo "unknown flag: $1" >&2; exit 2 ;;
    *)
      selected+=("$1"); shift ;;
  esac
done

# Decide which skills to install.
in_scope=()
if [ "${#selected[@]}" -gt 0 ]; then
  in_scope=("${selected[@]}")
elif [ -n "$scope" ]; then
  if ! jq -e --arg s "$scope" '.scopes | has($s)' "$CONFIG" >/dev/null; then
    echo "error: scope '$scope' not in config.json" >&2
    exit 2
  fi
  while IFS= read -r name; do
    in_scope+=("$name")
  done < <(jq -r --arg s "$scope" '.scopes[$s][]' "$CONFIG")
else
  while IFS= read -r name; do
    in_scope+=("$name")
  done < <(jq -r '[.scopes[][]] | unique | .[]' "$CONFIG")
fi

# Build set of "managed" skills — every skill the repo knows about across all
# scopes. Used to decide which existing symlinks should be removed when a
# narrower scope is requested.
managed_all=()
while IFS= read -r name; do
  managed_all+=("$name")
done < <(jq -r '[.scopes[][]] | unique | .[]' "$CONFIG")

run() {
  if $dry_run; then
    echo "  [dry-run] $*"
  else
    eval "$@"
  fi
}

contains() {
  local needle="$1"; shift
  local item
  for item in "$@"; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

mkdir -p "$SKILLS_DST"

# Phase 1: install / relink each requested skill.
for name in "${in_scope[@]+"${in_scope[@]}"}"; do
  src="$SKILLS_SRC/$name"
  dst="$SKILLS_DST/$name"

  if [ ! -d "$src" ]; then
    echo "missing  $name (not in repo)"
    continue
  fi

  if [ -L "$dst" ]; then
    current_target="$(readlink "$dst")"
    if [ "$current_target" = "$src" ]; then
      echo "identical $name"
      continue
    fi
    run "rm \"$dst\""
    run "ln -s \"$src\" \"$dst\""
    echo "relinked $name"
    continue
  fi

  if [ -e "$dst" ]; then
    echo "warning  $name — target exists and is not a symlink: $dst" >&2
    echo "         remove or rename it manually, then re-run." >&2
    exit 1
  fi

  run "ln -s \"$src\" \"$dst\""
  echo "linked   $name"
done

# Phase 2: when a scope is given (and we're not running by-name), remove
# symlinks for managed skills that fell out of this scope.
if [ -n "$scope" ] && [ "${#selected[@]}" -eq 0 ]; then
  for name in "${managed_all[@]}"; do
    contains "$name" "${in_scope[@]+"${in_scope[@]}"}" && continue
    dst="$SKILLS_DST/$name"
    [ -L "$dst" ] || continue
    current_target="$(readlink "$dst")"
    expected="$SKILLS_SRC/$name"
    [ "$current_target" = "$expected" ] || continue
    run "rm \"$dst\""
    echo "unlinked $name"
  done
fi
