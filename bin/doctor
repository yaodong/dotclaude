#!/usr/bin/env bash
# Report local setup for this repo without changing anything.

set -u

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG="$REPO_ROOT/config.json"
SKILLS_SRC="$REPO_ROOT/skills"
SKILLS_DST="$HOME/.claude/skills"
CONFIG_SRC="$REPO_ROOT/home"
CONFIG_DST="$HOME/.claude"

errors=0

line() {
  if [ "$#" -gt 2 ]; then
    printf '%-10s %-42s %s\n' "$1" "$2" "$3"
  else
    printf '%-10s %s\n' "$1" "$2"
  fi
}

valid() {
  line "valid" "$1"
}

invalid() {
  line "invalid" "$1" "$2"
  errors=$((errors + 1))
}

error() {
  local name="$1"
  local reason="${2:-not found}"
  line "missing" "$name" "$reason"
  errors=$((errors + 1))
}

link_status() {
  local name="$1"
  local src="$2"
  local dst="$3"
  local target

  if [ ! -e "$dst" ] && [ ! -L "$dst" ]; then
    error "$name" "not linked"
    return
  fi

  if [ ! -L "$dst" ]; then
    invalid "$name" "not a symlink"
    return
  fi

  target="$(readlink "$dst")"
  if [ "$target" = "$src" ]; then
    valid "$name"
  else
    invalid "$name" "wrong target"
  fi
}

echo "Overcommit"
if command -v overcommit >/dev/null 2>&1; then
  valid "overcommit installed ($(overcommit --version 2>/dev/null || command -v overcommit))"
else
  error "overcommit" "install with: gem install overcommit"
fi

if [ -f "$REPO_ROOT/.overcommit.yml" ]; then
  valid ".overcommit.yml exists"
else
  error ".overcommit.yml" "not found"
fi

echo
echo "Claude Skills"
if ! command -v jq >/dev/null 2>&1; then
  error "jq" "install with: brew install jq"
elif [ ! -f "$CONFIG" ]; then
  error "config.json" "not found"
else
  while IFS= read -r name; do
    link_status "$name" "$SKILLS_SRC/$name" "$SKILLS_DST/$name"
  done < <(jq -r '[.scopes[][]] | unique | .[]' "$CONFIG")

  echo
  echo "Claude Configs"
  while IFS= read -r name; do
    link_status "$name" "$CONFIG_SRC/$name" "$CONFIG_DST/$name"
  done < <(jq -r '[.configs[][]] | unique | .[]' "$CONFIG")
fi

if [ "$errors" -gt 0 ]; then
  exit 1
fi
